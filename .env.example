# 마음정산 환경변수 — 실제 secret 은 .env 에 입력 (이 파일은 형상관리용 placeholder).
# instrumentation.ts:register() 가 startup 시점에 src/lib/env.ts 의 validateEnv() 로 검증.
# 부재/형식 위반 시 throw → pm2 unstable restart → deploy.sh 의 /api/health smoke test 가 detect.

# === Required (부재 시 startup throw) ===
DATABASE_URL=postgresql://USER:PASS@HOST:6543/DB?pgbouncer=true   # Supabase pooled (PgBouncer)
DIRECT_URL=postgresql://USER:PASS@HOST:5432/DB                    # Supabase session pooler (Prisma migrate)
JWT_SECRET=                                                        # 32 chars+. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOSS_DECRYPT_KEY=                                                  # AES-256-GCM key (Toss userKey 복호화)
TOSS_DECRYPT_AAD=                                                  # AES-256-GCM AAD
TOSS_CALLBACK_SECRET=                                              # Toss /unlink 콜백 Basic Auth secret
CRON_SECRET=                                                       # 16 chars+. /api/cron/* 인증
GEMINI_API_KEY=                                                    # Google GenAI API key
RESEND_API_KEY=re_xxxxxxxxxxxx                                     # Resend transactional email

# === Optional (부재 시 일부 기능만 비활성, warn) ===
TOSS_MSG_TEMPLATE_CODE=                                            # 미설정 시 cron event-reminder 가 no_template_configured 로 noop
NEXT_PUBLIC_AD_GROUP_ID_AI_CREDIT=ait.v2.live.xxxxxxxxxxxx        # 미설정 시 AI 크레딧 광고 비활성
NEXT_PUBLIC_AD_GROUP_ID_CSV_CREDIT=ait.v2.live.xxxxxxxxxxxx       # 미설정 시 CSV 크레딧 광고 비활성
NEXT_PUBLIC_API_URL=https://maeum-jungsan.duckdns.org              # AIT 번들에서 EC2 호출 시 base URL

# === Optional / 크레딧·광고 정책 (코드에 fallback 있음) ===
AI_CREDIT_GUARD_ENABLED=true                                       # 'true' 일 때만 잔고 차감 가드
CSV_CREDIT_GUARD_ENABLED=true
AI_CREDIT_WELCOME=5
AI_CREDIT_CAP=5
AI_CREDIT_REWARD_AMOUNT=1
CSV_CREDIT_WELCOME=1
CSV_CREDIT_CAP=3
CSV_CREDIT_REWARD_AMOUNT=1
AD_DAILY_LIMIT=10                                                  # 검증 후 5 로 회귀 예정 (백로그)
AD_NONCE_TTL_MS=300000

# === Optional / 배포 환경 ===
APP_PORT=3000
# APP_URL=https://maeum-jungsan.duckdns.org                         # /api/analyze 의 self-call 시 사용
# NEXT_BUILD_CSR=1                                                  # AIT CSR 빌드 (build-ait.sh 가 자동 set)
