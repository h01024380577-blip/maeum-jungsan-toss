generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String    @id @default(cuid())
  tossUserKey          String?   @unique
  guestDeviceId        String?   @unique
  name                 String? // 복호화된 이름 (복호화 키 없으면 null)
  accessToken          String?
  refreshToken         String?
  tokenExpiresAt       DateTime?
  scopes               String? // space-separated scope list
  notificationsEnabled Boolean   @default(false)
  sessionVersion       Int       @default(0)

  // 크레딧 시스템 (2026-04-23 도입)
  aiCredits        Int      @default(1) // AI 분석 영구 잔고, 웰컴 1회
  csvImportCredits Int      @default(1) // CSV 가져오기 영구 잔고, 웰컴 1회
  adWatchesToday   Int      @default(0) // 오늘 본 리워드 광고 횟수 (AI/CSV 공용)
  adWatchesResetAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  contacts      Contact[]
  events        Event[]
  transactions  Transaction[]
  rewardGrants  AdRewardGrant[]
  paymentOrders PaymentOrder[]
}

enum RewardType {
  AI_CREDIT
  CSV_CREDIT
}

enum GrantStatus {
  ISSUED
  REDEEMED
  EXPIRED
  REJECTED
}

enum PaymentOrderStatus {
  CREATED
  EXECUTING
  EXECUTED
  FAILED
}

model AdRewardGrant {
  id           String      @id @default(cuid())
  userId       String
  adGroupId    String
  rewardNonce  String      @unique
  rewardType   RewardType
  rewardAmount Int
  status       GrantStatus @default(ISSUED)
  issuedAt     DateTime    @default(now())
  redeemedAt   DateTime?
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rewardNonce])
  @@index([issuedAt])
  @@index([userId, rewardType])
}

model PaymentOrder {
  id          String             @id @default(cuid())
  userId      String
  orderNo     String             @unique
  payToken    String             @unique
  amount      Int
  productDesc String
  status      PaymentOrderStatus @default(CREATED)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt
  executedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model Contact {
  id         String   @id @default(cuid())
  userId     String
  name       String
  phone      String   @default("")
  kakaoId    String?
  relation   String   @default("")
  avatar     String?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  events Event[]

  @@index([userId])
}

enum EventType {
  WEDDING
  FUNERAL
  BIRTHDAY
  OTHER
}

enum UiTheme {
  DEFAULT
  SOLEMN
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

model Event {
  id                String     @id @default(cuid())
  userId            String
  contactId         String?
  eventType         EventType
  targetName        String
  date              DateTime
  location          String     @default("")
  relation          String     @default("")
  sourceUrl         String?
  memo              String     @default("")
  customEventName   String?
  account           String     @default("")
  importFingerprint String?
  uiTheme           UiTheme    @default(DEFAULT)
  confidence        Confidence @default(MEDIUM)
  createdAt         DateTime   @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id])
  transactions Transaction[]

  @@unique([userId, importFingerprint])
  @@index([userId])
  @@index([date])
}

enum TransactionType {
  EXPENSE
  INCOME
}

enum TransactionSource {
  MANUAL
  URL
  OCR
  SMS_PASTE
  CSV
}

model Transaction {
  id                   String            @id @default(cuid())
  eventId              String
  userId               String
  type                 TransactionType
  amount               Int
  account              String            @default("")
  relation             String            @default("")
  recommendationReason String?
  isPaid               Boolean           @default(false)
  paidAt               DateTime?
  source               TransactionSource @default(MANUAL)
  createdAt            DateTime          @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
}
